<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>文图智洁 App 隐私策略</title>
    <style>
        /* ===== Reset & Base ===== */
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #2563eb;
            --primary-light: #3b82f6;
            --primary-dark: #1d4ed8;
            --primary-bg: #eff6ff;
            --accent: #e74c3c;
            --text-primary: #111827;
            --text-secondary: #374151;
            --text-muted: #6b7280;
            --text-light: #9ca3af;
            --bg-body: #f3f4f6;
            --bg-card: #ffffff;
            --border: #e5e7eb;
            --border-light: #f3f4f6;
            --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
            --shadow: 0 4px 24px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 8px 40px rgba(0, 0, 0, 0.12);
            --radius: 12px;
            --radius-sm: 8px;
            --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            --font: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
                "Hiragino Sans GB", "Microsoft YaHei", "Helvetica Neue",
                Helvetica, Arial, sans-serif;
        }

        /* Dark mode */
        @media (prefers-color-scheme: dark) {
            :root {
                --primary: #60a5fa;
                --primary-light: #93c5fd;
                --primary-dark: #3b82f6;
                --primary-bg: #1e293b;
                --accent: #f87171;
                --text-primary: #f1f5f9;
                --text-secondary: #cbd5e1;
                --text-muted: #94a3b8;
                --text-light: #64748b;
                --bg-body: #0f172a;
                --bg-card: #1e293b;
                --border: #334155;
                --border-light: #1e293b;
                --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.3);
                --shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
                --shadow-lg: 0 8px 40px rgba(0, 0, 0, 0.5);
            }
        }

        html {
            scroll-behavior: smooth;
            -webkit-text-size-adjust: 100%;
        }

        body {
            font-family: var(--font);
            background: var(--bg-body);
            color: var(--text-secondary);
            line-height: 1.8;
            padding: 24px;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ===== Container ===== */
        .container {
            max-width: 860px;
            margin: 0 auto;
            background: var(--bg-card);
            border-radius: var(--radius);
            padding: 48px 40px;
            box-shadow: var(--shadow);
            position: relative;
            animation: fadeIn 0.6s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ===== Header ===== */
        .header {
            text-align: center;
            padding-bottom: 28px;
            border-bottom: 2px solid var(--border);
            margin-bottom: 32px;
            position: relative;
        }

        .header::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 2px;
            background: var(--primary);
            border-radius: 2px;
        }

        .title {
            font-size: 28px;
            font-weight: 800;
            color: var(--text-primary);
            margin-bottom: 8px;
            line-height: 1.3;
            letter-spacing: 0.5px;
        }

        .title .highlight-text {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .time {
            color: var(--text-light);
            font-size: 14px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--bg-body);
            padding: 4px 16px;
            border-radius: 20px;
            margin-top: 4px;
        }

        .time::before {
            content: '📅';
            font-size: 14px;
        }

        /* ===== Table of Contents (Floating) ===== */
        .toc-toggle {
            display: none;
            position: fixed;
            bottom: 24px;
            right: 24px;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--primary);
            color: #fff;
            border: none;
            cursor: pointer;
            font-size: 20px;
            box-shadow: var(--shadow-lg);
            z-index: 1000;
            transition: var(--transition);
            align-items: center;
            justify-content: center;
        }

        .toc-toggle:hover {
            transform: scale(1.1);
            background: var(--primary-dark);
        }

        .toc-toggle.active {
            background: var(--accent);
        }

        .toc-panel {
            position: fixed;
            top: 0;
            right: -320px;
            width: 300px;
            height: 100vh;
            background: var(--bg-card);
            box-shadow: var(--shadow-lg);
            z-index: 999;
            padding: 24px 20px;
            overflow-y: auto;
            transition: right 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            border-left: 1px solid var(--border);
        }

        .toc-panel.open {
            right: 0;
        }

        .toc-panel .toc-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 2px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .toc-panel .toc-close {
            background: none;
            border: none;
            font-size: 20px;
            cursor: pointer;
            color: var(--text-muted);
            padding: 4px;
            transition: var(--transition);
        }

        .toc-panel .toc-close:hover {
            color: var(--text-primary);
        }

        .toc-list {
            list-style: none;
            padding: 0;
        }

        .toc-list li {
            margin-bottom: 2px;
        }

        .toc-list a {
            display: block;
            padding: 8px 12px;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 13px;
            border-radius: 6px;
            transition: var(--transition);
            border-left: 3px solid transparent;
        }

        .toc-list a:hover,
        .toc-list a.active {
            color: var(--primary);
            background: var(--primary-bg);
            border-left-color: var(--primary);
        }

        .toc-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.4);
            z-index: 998;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            backdrop-filter: blur(4px);
        }

        .toc-overlay.show {
            opacity: 1;
            pointer-events: auto;
        }

        /* ===== Back to Top ===== */
        .back-to-top {
            position: fixed;
            bottom: 80px;
            right: 24px;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: var(--bg-card);
            color: var(--text-muted);
            border: 1px solid var(--border);
            cursor: pointer;
            font-size: 18px;
            box-shadow: var(--shadow);
            z-index: 1000;
            transition: var(--transition);
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transform: translateY(20px);
            pointer-events: none;
        }

        .back-to-top.visible {
            opacity: 1;
            transform: translateY(0);
            pointer-events: auto;
        }

        .back-to-top:hover {
            background: var(--primary);
            color: #fff;
            border-color: var(--primary);
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
        }

        /* ===== Section Title ===== */
        .section-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-primary);
            margin: 40px 0 20px;
            padding: 12px 16px;
            padding-left: 20px;
            border-left: 4px solid var(--primary);
            background: linear-gradient(to right, var(--primary-bg), transparent);
            border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
            line-height: 1.4;
            scroll-margin-top: 20px;
        }

        .section-title:first-of-type {
            margin-top: 0;
        }

        .sub-title {
            font-size: 17px;
            font-weight: 600;
            color: var(--text-primary);
            margin: 24px 0 12px;
            padding: 8px 0;
            position: relative;
        }

        .sub-title::before {
            content: '';
            display: inline-block;
            width: 4px;
            height: 16px;
            background: var(--primary-light);
            border-radius: 2px;
            margin-right: 8px;
            vertical-align: middle;
        }

        /* ===== Content ===== */
        .content {
            font-size: 15px;
            color: var(--text-secondary);
        }

        .content > p {
            margin-bottom: 14px;
            text-align: justify;
            transition: var(--transition);
        }

        .content > p.indent {
            text-indent: 2em;
        }

        .highlight {
            font-weight: 600;
            color: var(--primary);
        }

        .bold {
            font-weight: 700;
            color: var(--text-primary);
        }

        /* ===== Overview Box ===== */
        .overview-box {
            background: linear-gradient(135deg, var(--primary-bg), #ffffff);
            border: 1px solid rgba(37, 99, 235, 0.15);
            border-radius: var(--radius-sm);
            padding: 24px;
            margin: 24px 0;
            position: relative;
            overflow: hidden;
        }

        .overview-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
            background: linear-gradient(to bottom, var(--primary), var(--primary-light));
            border-radius: 0 2px 2px 0;
        }

        .overview-box .bold {
            font-size: 16px;
            margin-bottom: 8px;
            display: block;
        }

        .overview-box p {
            margin-bottom: 8px;
            color: var(--text-secondary);
        }

        .overview-box p:last-child {
            margin-bottom: 0;
        }

        /* ===== Index List ===== */
        .index-list {
            list-style: none;
            padding: 0;
            margin: 16px 0 20px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4px;
        }

        .index-list li {
            padding: 10px 12px 10px 32px;
            position: relative;
            color: var(--text-secondary);
            font-size: 14px;
            border-radius: 6px;
            transition: var(--transition);
            cursor: default;
        }

        .index-list li:hover {
            background: var(--primary-bg);
        }

        .index-list li::before {
            content: '';
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            width: 8px;
            height: 8px;
            background: var(--primary);
            border-radius: 50%;
            transition: var(--transition);
        }

        .index-list li:hover::before {
            transform: translateY(-50%) scale(1.3);
        }

        .index-list li.highlight-item {
            font-weight: 600;
            color: var(--text-primary);
        }

        .index-list li.highlight-item::before {
            background: var(--accent);
        }

        @media (max-width: 600px) {
            .index-list {
                grid-template-columns: 1fr;
            }
        }

        /* ===== Table ===== */
        .table-wrapper {
            overflow-x: auto;
            margin: 24px 0;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            box-shadow: var(--shadow-sm);
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 13px;
            min-width: 700px;
        }

        thead {
            background: var(--primary-bg);
        }

        th {
            padding: 14px 12px;
            text-align: left;
            font-weight: 600;
            color: var(--text-primary);
            border-bottom: 2px solid var(--primary);
            white-space: nowrap;
            font-size: 13px;
        }

        td {
            padding: 12px;
            border-bottom: 1px solid var(--border);
            vertical-align: top;
            color: var(--text-secondary);
            line-height: 1.6;
        }

        tr:last-child td {
            border-bottom: none;
        }

        tbody tr {
            transition: var(--transition);
        }

        tbody tr:hover {
            background: var(--primary-bg);
        }

        /* ===== Link ===== */
        .link {
            color: var(--primary);
            word-break: break-all;
            font-size: 12px;
            text-decoration: none;
            transition: var(--transition);
        }

        .link:hover {
            color: var(--primary-dark);
            text-decoration: underline;
        }

        /* ===== Contact Info ===== */
        .contact-info {
            background: var(--bg-body);
            border-radius: var(--radius-sm);
            padding: 20px 24px;
            margin: 16px 0;
            border: 1px solid var(--border);
            transition: var(--transition);
        }

        .contact-info:hover {
            border-color: var(--primary);
            box-shadow: var(--shadow-sm);
        }

        .contact-info p {
            margin-bottom: 8px;
            display: flex;
            align-items: flex-start;
            gap: 8px;
        }

        .contact-info p:last-child {
            margin-bottom: 0;
        }

        .contact-info .label {
            font-weight: 600;
            color: var(--text-primary);
            min-width: 60px;
            flex-shrink: 0;
        }

        /* ===== Note ===== */
        .note {
            font-size: 13px;
            color: var(--text-light);
            margin-top: 4px;
            font-style: italic;
        }

        /* ===== Divider ===== */
        .divider {
            height: 1px;
            background: linear-gradient(to right, transparent, var(--border), transparent);
            margin: 32px 0;
        }

        /* ===== Footer ===== */
        .footer {
            margin-top: 40px;
            padding-top: 24px;
            border-top: 1px solid var(--border);
            text-align: center;
            font-size: 13px;
            color: var(--text-light);
        }

        .footer a {
            color: var(--primary);
            text-decoration: none;
        }

        .footer a:hover {
            text-decoration: underline;
        }

        /* ===== Responsive ===== */
        @media (max-width: 768px) {
            body {
                padding: 12px;
            }

            .container {
                padding: 24px 18px;
                border-radius: var(--radius-sm);
            }

            .title {
                font-size: 22px;
            }

            .content {
                font-size: 14px;
            }

            .section-title {
                font-size: 17px;
                margin: 28px 0 16px;
                padding: 10px 12px;
                padding-left: 16px;
            }

            .sub-title {
                font-size: 15px;
            }

            table {
                font-size: 12px;
                min-width: 600px;
            }

            th,
            td {
                padding: 8px 6px;
            }

            .overview-box {
                padding: 16px;
            }

            .toc-panel {
                width: 260px;
                right: -280px;
            }

            .toc-toggle {
                display: flex;
                bottom: 16px;
                right: 16px;
                width: 44px;
                height: 44px;
                font-size: 18px;
            }

            .back-to-top {
                bottom: 68px;
                right: 16px;
                width: 40px;
                height: 40px;
                font-size: 16px;
            }
        }

        @media (max-width: 480px) {
            body {
                padding: 8px;
            }

            .container {
                padding: 16px 12px;
            }

            .title {
                font-size: 19px;
            }

            .content {
                font-size: 13px;
            }

            .section-title {
                font-size: 15px;
                padding: 8px 10px;
                padding-left: 12px;
            }

            .sub-title {
                font-size: 14px;
            }

            .contact-info {
                padding: 14px 16px;
            }
        }

        /* ===== Print ===== */
        @media print {
            body {
                background: #fff;
                padding: 0;
                color: #333;
            }

            .container {
                box-shadow: none;
                padding: 20px;
                border-radius: 0;
                max-width: 100%;
            }

            .toc-toggle,
            .toc-panel,
            .toc-overlay,
            .back-to-top {
                display: none !important;
            }

            .section-title {
                break-inside: avoid;
            }

            .overview-box {
                border: 1px solid #ddd;
                background: #f9f9f9;
            }

            .table-wrapper {
                border: 1px solid #ddd;
            }

            a {
                color: #333 !important;
                text-decoration: underline !important;
            }
        }

        /* ===== Reduced Motion ===== */
        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
                scroll-behavior: auto !important;
            }
        }
    </style>
</head>
